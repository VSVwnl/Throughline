# My Olympian environment variables — copy to .env.local for local dev.
# The app runs end-to-end without any of these set (it returns mock content
# for every Gemini call), so judges can run it offline if needed.

# === Option A: AI Studio API key (simplest) ===
# Get a key from https://aistudio.google.com/app/apikey and uncomment:
# GEMINI_API_KEY=

# === Option B: Vertex AI on Google Cloud (recommended for hackathon credits) ===
# Run `gcloud auth application-default login` first, then uncomment:
# GOOGLE_VERTEXAI=1
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# === Optional model overrides ===
# Defaults are tuned to match the design document:
# - narrative: gemini-2.5-pro
# - chat:      gemini-2.5-flash
# - tts:       gemini-2.5-flash-preview-tts
# - image:     imagen-4.0-generate-001
# GEMINI_NARRATIVE_MODEL=gemini-2.5-pro
# GEMINI_CHAT_MODEL=gemini-2.5-flash
# GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
# GEMINI_IMAGE_MODEL=imagen-4.0-generate-001
